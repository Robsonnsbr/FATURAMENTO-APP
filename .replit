modules = ["python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt", "unixODBC", "unzip", "xcodebuild", "zlib"]

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3001

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[userenv]

[userenv.shared]
MSSQL_DB = "opus_hcm_221123"
